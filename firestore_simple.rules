rules_version = '2';

// ══════════════════════════════════════════════════════════
//  قواعد Firestore المبسّطة — مكتب جيل البناء
//  تعمل بدون Firebase Authentication
//  انسخ هذا المحتوى إلى:
//  Firebase Console → Firestore Database → Rules → Publish
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // عدّادات رقم الطلب اليومي
    match /counters/{dateKey} {
      allow read, write: if true;
    }

    // طلبات العملاء
    match /requests/{ticket} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;

      // رسائل الدردشة
      match /messages/{msgId} {
        allow read, write: if true;
      }
      // إشعارات العميل
      match /notifications/{notifId} {
        allow read, write: if true;
      }
    }

    // عروض الأسعار
    match /quotes/{quoteId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // إشعارات المكتب
    match /office_notifications/{notifId} {
      allow read, write: if true;
    }

    // موظفو المكتب (لن يُستخدم حالياً)
    match /staff/{uid} {
      allow read, write: if false;
    }
  }
}
