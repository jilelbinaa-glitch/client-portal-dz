rules_version = '2';

// ══════════════════════════════════════════════════════════
//  قواعد Firestore — مكتب جيل البناء
//  انسخ هذا المحتوى إلى:
//  Firebase Console → Firestore Database → Rules → Publish
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // بيانات العملاء (تسجيل الحساب)
    match /clients/{uid} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // عدّادات رقم الطلب
    match /counters/{doc} {
      allow read, write: if true;
    }

    // الطلبات
    match /requests/{ticket} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /messages/{msgId}      { allow read, write, delete: if true; }
      match /notifications/{nId}   { allow read, write, delete: if true; }
    }

    // عروض الأسعار
    match /quotes/{quoteId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // رسائل مستقلة
    match /messages/{msgId} {
      allow read, write, delete: if true;
    }

    // إشعارات المكتب
    match /office_notifications/{nId} {
      allow read, write, delete: if true;
    }

    // إشعارات العملاء
    match /notifications/{nId} {
      allow read, write, delete: if true;
    }
  }
}
